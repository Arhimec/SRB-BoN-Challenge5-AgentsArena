{
  "name": "guild-agents-bon",
  "version": "2.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "setup": "ts-node scripts/setup_wallets.ts",
    "register": "ts-node scripts/register_agents.ts",
    "llm": "ts-node scripts/llm_server.ts",
    "test-suite": "curl -s http://localhost:8080/test-suite | node -e \"const d=require('fs').readFileSync('/dev/stdin','utf8');const r=JSON.parse(d);console.log(r.accuracy+' ('+r.correct+'/'+r.total+')');r.results.forEach(x=>console.log(x.pass,x.message,'→',x.got,'(expected',x.expected+')'))\"",
    "connectivity": "ts-node scripts/bon_connectivity_test.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@multiversx/sdk-core": "^15.4.0",
    "@multiversx/sdk-wallet": "^4.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "node-fetch": "^2.7.0",
    "prom-client": "^15.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@types/node-fetch": "^2.6.13",
    "@types/ws": "^8.5.10",
    "jest": "^30.3.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  }
}
